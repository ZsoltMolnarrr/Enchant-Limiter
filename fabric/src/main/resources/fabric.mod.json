{
  "schemaVersion": 1,
  "id": "enchant_limiter",
  "version": "${version}",
  "name": "Enchant Limiter",
  "description": "Limit the number of enchantments on an item.",
  "authors": [
    "Daedelus"
  ],
  "contact": {
    "homepage": "https://fabricmc.net/",
    "sources": "https://github.com/FabricMC/fabric-example-mod"
  },
  "license": "GPL-3.0",
  "icon": "icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "net.enchant_limiter.fabric.ExampleModFabric"
    ],
    "client": [
      "net.enchant_limiter.fabric.client.ExampleModFabricClient"
    ]
  },
  "mixins": [
    "enchant_limiter.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": "~${minecraft_version}",
    "java": ">=21",
    "fabric-api": "*"
  },
  "suggests": {
    "another-mod": "*"
  }
}
